# AI Financial Advisor — Environment Variables
# On Render: go to your service → Environment → Add these

# Flask secret key (required — generate your own for production)
SECRET_KEY=your-secret-key-here-change-this

# SQLite database path (Render persistent disk or leave default)
# DB_PATH=/opt/render/project/src/backend/aifin.db

# Optional: Anthropic API key to enable Claude-powered chat
# ANTHROPIC_API_KEY=sk-ant-...

# Port is automatically set by Render — do NOT set this manually
# PORT=5000
